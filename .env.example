# ============================================================================
# Armenian Video Dubbing AI — Environment Variables
# ============================================================================
# Copy to .env and fill in your values:  cp .env.example .env
# ============================================================================

# --- Model Access ---
HF_TOKEN=hf_your_huggingface_token_here

# --- API Authentication ---
# Set to enable API key authentication. Leave empty to disable.
ARMTTS_API_KEY=

# --- CORS ---
# Comma-separated list of allowed origins. Default: * (allow all)
ARMTTS_CORS_ORIGINS=*

# --- GPU ---
CUDA_VISIBLE_DEVICES=0

# --- Config ---
ARMTTS_CONFIG=configs/config.yaml

# --- Experiment Tracking (optional) ---
WANDB_API_KEY=
WANDB_PROJECT=armenian-video-dubbing

# --- Label Studio (optional, dev only) ---
LABEL_STUDIO_URL=http://localhost:8080
LABEL_STUDIO_API_KEY=

# --- Cloud Deployment ---
# RunPod
RUNPOD_API_KEY=

# AWS (optional — uses aws configure credentials by default)
AWS_REGION=us-east-1
AWS_INSTANCE_TYPE=g5.xlarge
AWS_KEY_NAME=armtts-key

# GCP (optional — uses gcloud auth by default)
GCP_ZONE=us-central1-a
GCP_MACHINE_TYPE=n1-standard-8
GCP_GPU_TYPE=nvidia-tesla-t4
